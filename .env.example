# API Keys (provided by Rishabh, NEVER commit .env.local)
BACKBOARD_API_KEY=
BACKBOARD_ASSISTANT_ID=
BACKBOARD_API_URL=https://app.backboard.io/api
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
# Optional. Pin to a specific branch (version) of the ElevenLabs agent.
# If empty, the active branch from the dashboard is used.
ELEVENLABS_BRANCH_ID=
YOUTUBE_API_KEY=
# youtube-transcript.io — fetches timestamped captions so video
# activities can place inline questions at meaningful pause-points.
YOUTUBE_TRANSCRIPT_API_KEY=
DOCLING_SIDECAR_URL=http://localhost:8000

# Demo flags
NEXT_PUBLIC_USE_SEED_FALLBACK=false
NEXT_PUBLIC_VOICE_MODE=live
NEXT_PUBLIC_IMAGE_MODE=auto
